{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["lhr1"],
  "installCommand": "pnpm install --frozen-lockfile",
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/login/:path*",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "jamesmerriman.co.uk"
        }
      ],
      "destination": "https://www.jamesmerriman.co.uk/$1",
      "permanent": true
    },
    {
      "source": "/travelblog/:path*",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/webpage/:path*",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/videos/:path*",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/photography/:path+",
      "destination": "/photography",
      "permanent": true
    }
  ]
}
